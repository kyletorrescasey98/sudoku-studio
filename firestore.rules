rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PUZZLES ──────────────────────────────────────────────────────
    // Anyone (including guests) can read puzzles
    match /puzzles/{puzzleId} {
      allow read: if true;
      // Only authenticated users can create new puzzles
      allow create: if request.auth != null;
      // Only the puzzle author or an admin can update/delete
      allow update: if request.auth != null && (
        resource.data.authorUid == request.auth.uid ||
        request.auth.uid == 'app-seed'
      );
      allow delete: if request.auth != null && resource.data.authorUid == request.auth.uid;

      // Solvers sub-collection: anyone can read, authenticated users can write their own
      match /solvers/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Comments sub-collection: anyone can read, authenticated users can create,
      // only the comment author can update/delete their own comment
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
          resource.data.uid == request.auth.uid ||
          // allow incrementing replyCount when a reply is posted
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount']) ||
          // allow incrementing/decrementing likeCount when anyone likes/unlikes
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount'])
        );
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;

        // Replies sub-collection
        match /replies/{replyId} {
          allow read: if true;
          allow create: if request.auth != null;
          allow update: if request.auth != null && (
            resource.data.uid == request.auth.uid ||
            // allow incrementing/decrementing likeCount when anyone likes/unlikes
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount'])
          );
          allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
        }
      }
    }

    // ── USERS ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone can read a user's public profile
      allow read: if true;
      // Only the user themselves can write to their own document
      allow write: if request.auth != null && request.auth.uid == userId;
      // Any authenticated user can update another user's 'followers' field only
      // (needed for follow/unfollow actions — writer can only touch 'followers')
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']);

      // Solves sub-collection
      match /solves/{solveId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Started sub-collection (in-progress puzzles)
      match /started/{puzzleId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Comment likes — user can only manage their own like records
      match /commentLikes/{likeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Reply likes — user can only manage their own like records
      match /replyLikes/{likeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

  }
}
